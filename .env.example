# Copy to .env (gitignored) and fill in. Never commit real secrets.

# OmniRoute API key for routing model traffic.
OMNIROUTE_API_KEY=

# Path to the forge binary (defaults to "forge" on PATH).
# Tests/--fake override this to the bundled fake-forge.
FORGE_BIN=

# ── Phase 5: engine adapters ──────────────────────────────────────────────────

# Path to the codex CLI binary (defaults to "codex" on PATH).
CODEX_BIN=

# Codex Cloud environment id for `codex cloud exec --env` (cloud-codex adapter).
CODEX_CLOUD_ENV_ID=

# Set to "1" to run real codex integration tests (requires CODEX_BIN to work).
CODEX_INTEGRATION=

# Path to the claude CLI binary (defaults to "claude" on PATH).
CLAUDE_BIN=

# Set to "1" to run real claude integration tests (requires CLAUDE_BIN to work).
CLAUDE_INTEGRATION=

# Base URL of the agentapi-plusplus server (default: http://localhost:3284).
AGENTAPI_ENDPOINT=

# Set to "1" to run real agentapi integration tests (requires AGENTAPI_ENDPOINT).
AGENTAPI_INTEGRATION=

# ── Phase 5: trace adapters ───────────────────────────────────────────────────

# Base URL of the AgilePlus API server (default: http://localhost:4000).
AGILEPLUS_ENDPOINT=

# Base URL of the Tracera API server (default: http://localhost:5000).
TRACERA_ENDPOINT=
